# MongoDB Connection
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/dearluna?retryWrites=true&w=majority

# Port (Render/Railway will set this automatically, but you can set it for local testing)
PORT=5000

# Email (SMTP) Configuration
# These can also be configured via the Admin Dashboard in the app
FRONTEND_URL=https://your-dearluna-frontend.vercel.app
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_SECURE=false
EMAIL_FROM="DearLuna" <no-reply@dearluna.app>
